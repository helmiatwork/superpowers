#!/bin/bash
# Rebuild all AI Redis keys from source of truth
# Priority: Outline → local backup (superpowers/redis-backup/) → fail
# Run after: redis flush, new machine, or just to refresh

set -e

BACKUP_DIR="$HOME/.config/opencode/superpowers/redis-backup"

echo "🔄 Rebuilding AI Redis keys..."

load_from_outline_or_backup() {
  local redis_key=$1
  local outline_id=$2
  local backup_file=$3

  content=$(python3 -c "
import json, urllib.request
req = urllib.request.Request('http://localhost:3000/api/documents.info',
    json.dumps({'id': '$outline_id'}).encode(),
    headers={'Authorization': 'Bearer ol_api_L7Xvu9kYtSNqdamjbLSORrJ2kdOQhdvCHZlW6H', 'Content-Type': 'application/json'})
print(json.loads(urllib.request.urlopen(req).read())['data']['text'])
" 2>/dev/null) || content=""

  if [ -n "$content" ]; then
    redis-cli SET "$redis_key" "$content" > /dev/null
    echo "  ✅ $redis_key ($(redis-cli STRLEN "$redis_key") bytes) — from Outline"
  elif [ -f "$BACKUP_DIR/$backup_file" ]; then
    redis-cli SET "$redis_key" "$(cat "$BACKUP_DIR/$backup_file")" > /dev/null
    echo "  ⚠️  $redis_key ($(redis-cli STRLEN "$redis_key") bytes) — from local backup"
  else
    echo "  ❌ $redis_key — FAILED (no Outline, no backup)"
  fi
}

# 1. From Outline (fallback to backup)
load_from_outline_or_backup "ai:strategy" "5a830d18-ffdf-4368-80c0-aff2a035a224" "ai-strategy.md"
load_from_outline_or_backup "ai:execution-protocol" "2149642d-1da4-4f18-b259-548586cf0733" "ai-execution-protocol.md"

# 2. Templates index
content=$(python3 -c "
import json, urllib.request
req = urllib.request.Request('http://localhost:3000/api/collections.documents',
    json.dumps({'id': 'd8923b12-4e5c-45c3-b656-383055a46df5'}).encode(),
    headers={'Authorization': 'Bearer ol_api_L7Xvu9kYtSNqdamjbLSORrJ2kdOQhdvCHZlW6H', 'Content-Type': 'application/json'})
docs = json.loads(urllib.request.urlopen(req).read())['data']
print('Project Templates Collection (Outline ID: d8923b12-4e5c-45c3-b656-383055a46df5)')
print()
print('Documents:')
for d in sorted(docs, key=lambda x: x['title']):
    print(f\"- {d['title']} ({d['id'][:8]})\")" 2>/dev/null) || content=""

if [ -n "$content" ]; then
  redis-cli SET "ai:templates:index" "$content" > /dev/null
  echo "  ✅ ai:templates:index ($(redis-cli STRLEN ai:templates:index) bytes) — from Outline"
elif [ -f "$BACKUP_DIR/ai-templates-index.md" ]; then
  redis-cli SET "ai:templates:index" "$(cat "$BACKUP_DIR/ai-templates-index.md")" > /dev/null
  echo "  ⚠️  ai:templates:index ($(redis-cli STRLEN ai:templates:index) bytes) — from backup"
else
  echo "  ❌ ai:templates:index — FAILED"
fi

# 3. From local files
redis-cli SET ai:agent-config "$(cat ~/.config/opencode/oh-my-opencode-slim.json)" > /dev/null
echo "  ✅ ai:agent-config ($(redis-cli STRLEN ai:agent-config) bytes)"

redis-cli SET ai:workflow-guide "$(cat ~/.config/opencode/superpowers/skills/using-superpowers/SKILL.md)" > /dev/null
echo "  ✅ ai:workflow-guide ($(redis-cli STRLEN ai:workflow-guide) bytes)"

# 4. Session state
echo ""
echo "  ⚠️  ai:state:* / ai:tasks:* / ai:feature:* are session-specific — recreated on next session"

# 5. Summary
echo ""
echo "📊 Redis keys:"
redis-cli KEYS "ai:*" | sort | while read key; do
  echo "  $key ($(redis-cli STRLEN "$key") bytes)"
done
echo ""
echo "✅ Done"
